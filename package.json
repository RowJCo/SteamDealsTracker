{
  "name": "steamdealstracker",
  "type": "module",
  "version": "1.0.0",
  "description": "A web app that allows you to pick a steam game and a price and receive alerts when the game goes on sale to that ammount.",
  "scripts": {
    "prestart": "node lib/setupDb.js && node lib/setupSteamData.js",
    "start": "next start",
    "predev": "node lib/setupDb.js && node lib/setupSteamData.js",
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint"
  },
  "author": "Rowen Collier",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.2.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "daisyui": "^4.12.12",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  }
}
